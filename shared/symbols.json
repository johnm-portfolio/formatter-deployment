  "formulae": [
    {
      "pattern": "!sum\\((.*?)\\)\\((.*?)\\)!",
      "replacement": "$\\sum_{\\1}^{\\2}$",
      "description": "Summation notation"
    },
    {
      "pattern": "!sqrt\\((.*?)\\)!",
      "replacement": "$\\sqrt{\\1}$",
      "description": "Square root notation",
      "categories": ["formulae-notation"]
    },
    {
      "pattern": "!\\((.*?)\\)/\\((.*?)\\)!",
      "replacement": "$\\frac{\\1}{\\2}$",
      "description": "Fraction notation",
      "categories": ["formulae-notation"]
    },
    {
      "pattern": "!log\\((.*?)\\)!",
      "replacement": "$\\log{\\1}$",
      "description": "Logarithm with argument",
      "categories": ["formulae-notation"]
    },
    {
      "pattern": "!floor\\((.*?)\\)!",
      "replacement": "$\\lfloor$\\1$\\rfloor$",
      "description": "Floor notation",
      "categories": ["formulae-notation"]
    },
    {
      "pattern": "!rdown\\((.*?)\\)!",
      "replacement": "$\\lfloor$\\1$\\rfloor$",
      "description": "Floor notation alias",
      "categories": ["formulae-notation"]
    },
    {
      "pattern": "!ceil\\((.*?)\\)!",
      "replacement": "$\\lceil$\\1$\\rceil$",
      "description": "Ceiling notation",
      "categories": ["formulae-notation"]
    },
    {
      "pattern": "!rup\\((.*?)\\)!",
      "replacement": "$\\lceil$\\1$\\rceil$",
      "description": "Ceiling notation alias",
      "categories": ["formulae-notation"]
    }
  ]
}